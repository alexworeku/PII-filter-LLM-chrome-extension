{
  "manifest_version": 3,
  "name": "PII Shield",
  "version": "1.1.0",
  "description": "Detects and masks PII in AI chat inputs, then unmasks the assistant's reply so you see your original data. Runs fully offline.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PII Shield"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
